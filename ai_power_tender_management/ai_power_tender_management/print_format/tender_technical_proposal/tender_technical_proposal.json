 "html": "<div dir=\"rtl\" style=\"font-family:'Tahoma','Segoe UI',Arial,sans-serif;color:#1f2430;line-height:1.7;\">\n\t<div style=\"background:linear-gradient(120deg,#4f46e5,#7c3aed);color:#fff;border-radius:14px;padding:24px 26px;margin-bottom:22px;\">\n\t\t<h1 style=\"margin:0 0 6px;font-size:24px;color:#fff;\">العرض الفني</h1>\n\t\t<div style=\"opacity:.85;font-size:14px;\">{{ doc.tender_name or \"\" }}</div>\n\t\t<div style=\"margin-top:14px;display:grid;grid-template-columns:1fr 1fr;gap:6px 24px;font-size:13px;\">\n\t\t\t<div><b>المناقصة:</b> {{ doc.tender_name or \"—\" }}</div>\n\t\t\t<div><b>رقم المناقصة:</b> {{ doc.tender_number or \"—\" }}</div>\n\t\t\t<div><b>الجهة:</b> {{ doc.client_name or \"—\" }}</div>\n\t\t\t<div><b>تاريخ الإقفال:</b> {{ doc.get_formatted(\"closing_date\") or \"—\" }}</div>\n\t\t</div>\n\t</div>\n\n\t{% if doc.proposal_sections %}\n\t\t{% for s in doc.proposal_sections %}\n\t\t<section style=\"margin-bottom:20px;padding:18px 20px;border:1px solid #e6e8ee;border-radius:12px;page-break-inside:avoid;\">\n\t\t\t<h2 style=\"margin:0 0 10px;font-size:17px;color:#4f46e5;border-bottom:2px solid #eef0f6;padding-bottom:8px;\">{{ loop.index }}. {{ s.title or s.section_type }}</h2>\n\t\t\t<div style=\"font-size:14px;\">{{ (s.content or \"\") | safe }}</div>\n\t\t</section>\n\t\t{% endfor %}\n\t{% else %}\n\t\t<p style=\"color:#999;\">{{ _(\"No proposal sections generated yet.\") }}</p>\n\t{% endif %}\n</div>\n",
