 "html": "<div style=\"font-family:Arial,'Segoe UI',sans-serif;color:#1f2430;\">\n\t<h1 style=\"font-size:20px;margin:0 0 4px;\">Financial Proposal</h1>\n\t<div style=\"font-size:13px;color:#555;margin-bottom:14px;\">\n\t\t{{ doc.tender_name or \"\" }}{% if doc.tender_number %} &mdash; {{ doc.tender_number }}{% endif %}\n\t</div>\n\n\t<table style=\"width:100%;border-collapse:collapse;font-size:12px;\">\n\t\t<thead>\n\t\t\t<tr style=\"background:#4f46e5;color:#fff;\">\n\t\t\t\t<th style=\"border:1px solid #ccc;padding:6px;text-align:center;\">#</th>\n\t\t\t\t<th style=\"border:1px solid #ccc;padding:6px;text-align:right;\">Description</th>\n\t\t\t\t<th style=\"border:1px solid #ccc;padding:6px;text-align:center;\">Unit</th>\n\t\t\t\t<th style=\"border:1px solid #ccc;padding:6px;text-align:center;\">Qty</th>\n\t\t\t\t<th style=\"border:1px solid #ccc;padding:6px;text-align:right;\">Unit Price</th>\n\t\t\t\t<th style=\"border:1px solid #ccc;padding:6px;text-align:right;\">Total</th>\n\t\t\t</tr>\n\t\t</thead>\n\t\t<tbody>\n\t\t\t{% for row in doc.boq_items %}\n\t\t\t\t{% if row.line_type == \"Section Heading\" %}\n\t\t\t\t<tr>\n\t\t\t\t\t<td style=\"border:1px solid #ccc;padding:6px;text-align:center;\">{{ row.item_no or \"\" }}</td>\n\t\t\t\t\t<td colspan=\"5\" style=\"border:1px solid #ccc;padding:6px;font-weight:bold;background:#f3f4f6;\">{{ row.description }}</td>\n\t\t\t\t</tr>\n\t\t\t\t{% else %}\n\t\t\t\t<tr>\n\t\t\t\t\t<td style=\"border:1px solid #ccc;padding:6px;text-align:center;\">{{ row.item_no or loop.index }}</td>\n\t\t\t\t\t<td style=\"border:1px solid #ccc;padding:6px;text-align:right;\">{{ row.description }}{% if row.specification %}<div style=\"font-size:11px;color:#777;\">{{ row.specification }}</div>{% endif %}</td>\n\t\t\t\t\t<td style=\"border:1px solid #ccc;padding:6px;text-align:center;\">{{ row.unit or \"\" }}</td>\n\t\t\t\t\t<td style=\"border:1px solid #ccc;padding:6px;text-align:center;\">{{ row.quantity }}</td>\n\t\t\t\t\t<td style=\"border:1px solid #ccc;padding:6px;text-align:right;\">{{ row.get_formatted(\"unit_price\") }}</td>\n\t\t\t\t\t<td style=\"border:1px solid #ccc;padding:6px;text-align:right;\">{{ row.get_formatted(\"total\") }}</td>\n\t\t\t\t</tr>\n\t\t\t\t{% endif %}\n\t\t\t{% endfor %}\n\t\t</tbody>\n\t</table>\n\n\t<div style=\"margin-top:16px;width:320px;margin-left:auto;font-size:13px;\">\n\t\t<div style=\"display:flex;justify-content:space-between;padding:5px 0;\"><span>Subtotal</span><b>{{ doc.get_formatted(\"boq_subtotal\") }}</b></div>\n\t\t<div style=\"display:flex;justify-content:space-between;padding:5px 0;\"><span>VAT ({{ doc.vat_rate | int }}%)</span><b>{{ doc.get_formatted(\"vat_amount\") }}</b></div>\n\t\t<div style=\"display:flex;justify-content:space-between;padding:8px 0;border-top:2px solid #333;font-size:15px;\"><span>Grand Total</span><b>{{ doc.get_formatted(\"boq_grand_total\") }}</b></div>\n\t</div>\n</div>\n",
